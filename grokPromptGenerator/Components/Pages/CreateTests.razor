</div>

@* Checkboxes - Integration-test Specific *@
<h6 class="mb-2 fw-bold text-secondary">Integration-test Specific</h6>
<div class="list-group mb-3" style="max-width: 650px;">
    @foreach (var item in MenuItems5)
    {
        <label class="list-group-item d-flex align-items-center">
            <input class="form-check-input me-2" type="checkbox" @bind="item.IsSelected" @bind:after="() => { }" />
            @item.Name
        </label>
    }
    <!-- New Input Row -->
    <div class="list-group-item p-0">
        <div class="input-group">
            <input type="text" class="form-control border-0"
                   placeholder="Add custom item..."
                   @bind="newItemName5"
                   @onkeyup="HandleKeyUp5" />
            <button class="btn btn-outline-secondary border-0" type="button" @onclick="AddItem5">
                <i class="bi bi-plus-lg">Add</i>
            </button>
        </div>
    </div>
</div>

@* Checkboxes - Code Coverage *@
<h6 class="mb-2 fw-bold text-secondary">Code Coverage</h6>
<div class="list-group mb-3" style="max-width: 650px;">
    @foreach (var item in MenuItems6)
    {
        <label class="list-group-item d-flex align-items-center">
            <input class="form-check-input me-2" type="checkbox" @bind="item.IsSelected" @bind:after="() => { }" />
            @item.Name
        </label>
    }
    <!-- New Input Row -->
    <div class="list-group-item p-0">
        <div class="input-group">
            <input type="text" class="form-control border-0"
                   placeholder="Add custom item..."
                   @bind="newItemName6"
                   @onkeyup="HandleKeyUp6" />
            <button class="btn btn-outline-secondary border-0" type="button" @onclick="AddItem6">
                <i class="bi bi-plus-lg">Add</i>
            </button>
        </div>
    </div>
</div>

@code {
    private string SelectedTestType = "unit"; // Default selection
    private string ClassName { get; set; } = "myClassName";
    private string FileName { get; set; } = "";
    private string TestFile { get; set; } = "myTestFile";

    private string newItemName1 = "";
    private string newItemName2 = "";
    private string newItemName3 = "";
    private string newItemName4 = "";
    private string newItemName5 = "";
    private string newItemName6 = "";

    // Define a simple class to hold the menu item state
    public class MenuItem
    {
        public string Name { get; set; } = string.Empty;
        public bool IsSelected { get; set; }
    }

    // Initialize your menu list
    private List<MenuItem> MenuItems1 = new()
    {
        // framework selection:
        new MenuItem { Name = "Use NUnit" },
        new MenuItem { Name = "Use xUnit" },
        new MenuItem { Name = "Use MSTest" },
    };

    private void AddItem1()
    {
        if (!string.IsNullOrWhiteSpace(newItemName1))
        {
            MenuItems1.Add(new MenuItem { Name = newItemName1, IsSelected = true });
            newItemName1 = "";
        }
    }

    private void HandleKeyUp1(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddItem1();
        }
    }

    private List<MenuItem> MenuItems2 = new()
    {
        // standards:
        new MenuItem { Name = "Follow the AAA (Arrange, Act, Assert) pattern with clear comments" },
        new MenuItem { Name = "Use the MethodName_StateUnderTest_ExpectedBehavior naming convention" },
    };

    private void AddItem2()
    {
        if (!string.IsNullOrWhiteSpace(newItemName2))
        {
            MenuItems2.Add(new MenuItem { Name = newItemName2, IsSelected = true });
            newItemName2 = "";
        }
    }

    private void HandleKeyUp2(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddItem2();
        }
    }

    private List<MenuItem> MenuItems3 = new()
    {
        // functionalScenarios:
        new MenuItem { Name = "Include tests for normal expected inputs" },
        new MenuItem { Name = "Include tests for boundary conditions" },
        new MenuItem { Name = "Include tests for null and empty inputs" },
        new MenuItem { Name = "Include tests for invalid inputs" },
    };

    private void AddItem3()
    {
        if (!string.IsNullOrWhiteSpace(newItemName3))
        {
            MenuItems3.Add(new MenuItem { Name = newItemName3, IsSelected = true });
            newItemName3 = "";
        }
    }

    private void HandleKeyUp3(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddItem3();
        }
    }

    private List<MenuItem> MenuItems4 = new()
    {
        // nonFunctionalTesting:
        new MenuItem { Name = "Include tests for performance"},
        new MenuItem { Name = "Include tests for security" },
        new MenuItem { Name = "Include tests for usability" },
    };

    private void AddItem4()
    {
        if (!string.IsNullOrWhiteSpace(newItemName4))
        {
            MenuItems4.Add(new MenuItem { Name = newItemName4, IsSelected = true });
            newItemName4 = "";
        }
    }

    private void HandleKeyUp4(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddItem4();
        }
    }

    private List<MenuItem> MenuItems5 = new()
    {
        // integration-specific:
        new MenuItem { Name = "Verify database state changes" },
        new MenuItem { Name = "Ensure cleanup after tests"},
        new MenuItem { Name = "Verify API response status codes and payload structures"},
    };

    private void AddItem5()
    {
        if (!string.IsNullOrWhiteSpace(newItemName5))
        {
            MenuItems5.Add(new MenuItem { Name = newItemName5, IsSelected = true });
            newItemName5 = "";
        }
    }

    private void HandleKeyUp5(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddItem5();
        }
    }

    private List<MenuItem> MenuItems6 = new()
    {
        // codeCoverage:
        new MenuItem { Name = "Aim for at least 80% code coverage" },
        new MenuItem { Name = "Include tests for all critical paths" },
        new MenuItem { Name = "Include tests for error handling paths" },
    };

    private void AddItem6()
    {
        if (!string.IsNullOrWhiteSpace(newItemName6))
        {
            MenuItems6.Add(new MenuItem { Name = newItemName6, IsSelected = true });
            newItemName6 = "";
        }
    }

    private void HandleKeyUp6(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddItem6();
        }
    }

    // This is a Calculated Property:
    private List<string> SelectedItemsList => MenuItems1
        .Concat(MenuItems2)
        .Concat(MenuItems3)
        .Concat(MenuItems4)
        .Concat(MenuItems5)
        .Concat(MenuItems6)
        .Where(i => i.IsSelected)
        .Select(i => i.Name)
        .ToList();

    private async Task CopyToClipboard()
    {
        // Build the full prompt string manually to match your UI layout
        var fullPrompt = $"Please generate tests for (tested class or method:) \"{ClassName}\"";
        if (!string.IsNullOrWhiteSpace(FileName)) fullPrompt += $"\nunder (namespace:) \"{FileName}\"";
        if (!string.IsNullOrWhiteSpace(TestFile)) fullPrompt += $"\nwith the test file: \"{TestFile}\"";
        if (SelectedItemsList.Any()) fullPrompt += "\n   - " + string.Join("\n   - ", SelectedItemsList);

        // Call the browser's built-in clipboard function
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", fullPrompt);
    }
}
