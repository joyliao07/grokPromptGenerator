@page "/createTests"
@* This line enables the C# code to respond to browser events *@
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime

<PageTitle>Create Tests</PageTitle>

<h1>Create Tests</h1>

<p>Use this tool to generate prompts for the AI to create new unit/integration tests.</p>

@* Final Output with Line Breaks *@
<div class="mt-3 p-3 border bg-light position-relative" style="white-space: pre-line;">
    <strong>Generated Prompt:</strong>
    @* Copy Button with Icon *@
    <button class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-2"
            @onclick="CopyToClipboard" title="Copy to clipboard">
        <i class="bi bi-clipboard"></i> Copy
    </button>
    <div>
        <p>Please generate <span style="color: blue;">@SelectedTestType</span> tests for (tested class or method:) "<span style="color: blue;">@ClassName</span>" </p>
        @if (!string.IsNullOrWhiteSpace(FileName))
        {
            <p><span>under (namespace:) "<span style="color: blue;">@FileName</span>"</span></p>
        }
        @if (!string.IsNullOrWhiteSpace(TestFile))
        {
            <p><span>with test file: "<span style="color: blue;">@TestFile</span>"</span></p>
        }
        <pre>
            @if (SelectedItemsList.Any())
            {
                @("   - " + string.Join("\n   - ", SelectedItemsList))
            }
        </pre>
    </div>
</div>

@* Type of tests *@
<div class="mt-3 mb-3">
    <h6 class="mb-2 fw-bold text-secondary">Type of Tests:</h6>
    <div class="form-check">
        <input class="form-check-input" type="radio" name="testTypeGroup" id="unit" value="Unit"
               checked="@(SelectedTestType == "unit")"
               @onchange="@(() => SelectedTestType = "unit")" />
        <label class="form-check-label" for="unit">Unit</label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="radio" name="testTypeGroup" id="integration" value="Integration"
               checked="@(SelectedTestType == "integration")"
               @onchange="@(() => SelectedTestType = "integration")" />
        <label class="form-check-label" for="integration">Integration</label>
    </div>
</div>

@* Text Input: Class Name *@
<div class="mb-3 mt-4" style="max-width: 650px;">
    <label for="className" class="form-label">Class Name:</label>
    <input type="text"
           id="className"
           class="form-control"
           placeholder="Enter name..."
           maxlength="200"
           @bind="ClassName"
           @bind:event="oninput" />
    <small class="text-muted">@ClassName.Length / 200</small>
</div>

@* Text Input: File Name *@
<div class="mb-3" style="max-width: 650px;">
    <label for="namespace" class="form-label">namespace (optional):</label>
    <input type="text"
           id="namespace"
           class="form-control"
           placeholder="Enter name..."
           maxlength="200"
           @bind="FileName"
           @bind:event="oninput" />
    <small class="text-muted">@FileName.Length / 200</small>
</div>

@* Text Input: Test File Name *@
<div class="mb-3" style="max-width: 650px;">
    <label for="namespace" class="form-label">test file (optional):</label>
    <input type="text"
           id="namespace"
           class="form-control"
           placeholder="Enter name..."
           maxlength="200"
           @bind="TestFile"
           @bind:event="oninput" />
    <small class="text-muted">@TestFile.Length / 200</small>
</div>

@* Checkboxes - Framework Selection*@
<h6 class="mb-2 fw-bold text-secondary">Framework Selection</h6>
<div class="list-group mb-3" style="max-width: 650px;">
    @foreach (var item in MenuItems1)
    {
        <label class="list-group-item d-flex align-items-center">
            <input class="form-check-input me-2" type="checkbox" @bind="item.IsSelected" @bind:after="() => { }"/>
            @item.Name
        </label>
    }
    <!-- New Input Row -->
    <div class="list-group-item p-0">
        <div class="input-group">
            <input type="text" class="form-control border-0"
                   placeholder="Add custom item..."
                   @bind="newItemName1"
                   @onkeyup="HandleKeyUp1" />
            <button class="btn btn-outline-secondary border-0" type="button" @onclick="AddItem1">
                <i class="bi bi-plus-lg">Add</i>
            </button>
        </div>
    </div>
</div>

@* Checkboxes - Testing Standards *@
<h6 class="mb-2 fw-bold text-secondary">Testing Standards</h6>
<div class="list-group mb-3" style="max-width: 650px;">
    @foreach (var item in MenuItems2)
    {
        <label class="list-group-item d-flex align-items-center">
            <input class="form-check-input me-2" type="checkbox" @bind="item.IsSelected" @bind:after="() => { }"/>
            @item.Name
        </label>
    }
    <!-- New Input Row -->
    <div class="list-group-item p-0">
        <div class="input-group">
            <input type="text" class="form-control border-0"
                   placeholder="Add custom item..."
                   @bind="newItemName2"
                   @onkeyup="HandleKeyUp2" />
            <button class="btn btn-outline-secondary border-0" type="button" @onclick="AddItem2">
                <i class="bi bi-plus-lg">Add</i>
            </button>
        </div>
    </div>
</div>

@* Checkboxes - Functional Scenarios *@
<h6 class="mb-2 fw-bold text-secondary">Functional Scenarios</h6>
<div class="list-group mb-3" style="max-width: 650px;">
    @foreach (var item in MenuItems3)
    {
        <label class="list-group-item d-flex align-items-center">
            <input class="form-check-input me-2" type="checkbox" @bind="item.IsSelected" @bind:after="() => { }" />
            @item.Name
        </label>
    }
    <!-- New Input Row -->
    <div class="list-group-item p-0">
        <div class="input-group">
            <input type="text" class="form-control border-0"
                   placeholder="Add custom item..."
                   @bind="newItemName3"
                   @onkeyup="HandleKeyUp3" />
            <button class="btn btn-outline-secondary border-0" type="button" @onclick="AddItem3">
                <i class="bi bi-plus-lg">Add</i>
            </button>
        </div>
    </div>
</div>

@* Checkboxes - Non-Functional Testing *@
<h6 class="mb-2 fw-bold text-secondary">Non-Functional Testing</h6>
<div class="list-group mb-3" style="max-width: 650px;">
    @foreach (var item in MenuItems4)
    {
        <label class="list-group-item d-flex align-items-center">
            <input class="form-check-input me-2" type="checkbox" @bind="item.IsSelected" @bind:after="() => { }" />
            @item.Name
        </label>
    }
    <!-- New Input Row -->
    <div class="list-group-item p-0">
        <div class="input-group">
            <input type="text" class="form-control border-0"
                   placeholder="Add custom item..."
                   @bind="newItemName4"
                   @onkeyup="HandleKeyUp4" />
            <button class="btn btn-outline-secondary border-0" type="button" @onclick="AddItem4">
                <i class="bi bi-plus-lg">Add</i>
            </button>
